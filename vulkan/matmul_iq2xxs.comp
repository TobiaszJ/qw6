/* ---- Grid value accessor ---- */

/* Extract the j-th byte (0..7) from the 64-bit grid entry at index idx */
uint grid_byte_at(uint idx, uint j) {
    uint lo = iq2xxs_grid_lo[idx];
    uint hi = iq2xxs_grid_hi[idx];
    return (j < 4) ? ((lo >> (j * 8)) & 255) : ((hi >> ((j - 4) * 8)) & 255);
}

/* ---- Main kernel ---- */

void main() {
    uint row = gl_WorkGroupID.x;
    uint lid = gl_LocalInvocationID.x;
    if (row >= pc.rows) return;

    uint n_blocks = pc.cols / 256;
    float acc = 0.0;
    for (uint b = 0; b < n_blocks; b++) {
        uint block_base = (row * n_blocks + b) * 66;

        /* d = FP16 scale for this block */
        float d = fp16_to_f32(u16_at(block_base, 0));

        /* Each thread handles its column c within the block */
        uint c = lid;  /* local column within this block (0..255) */
        uint ib32 = c / 32;
        uint in_ib32 = c % 32;
        uint l = in_ib32 / 8;     /* group 0..3 within ib32 */
        uint j = in_ib32 % 8;     /* position 0..7 within group */

        /* Read the 8-byte ib32 chunk at offset 2 + ib32 * 8 */
        uint chunk_base = block_base + 2 + ib32 * 8;
        uint aux0 = read_u32_at(chunk_base);       /* grid indices (4 × byte) */
        uint aux1 = read_u32_at(chunk_base + 4);   /* sign indices + scale */

        /* Scale factor for this sub-block */
        uint scale_extra = aux1 >> 28;
        float db = d * (0.5 + float(scale_extra)) * 0.25;

        /* Grid index: byte l of aux0 */
        uint grid_idx = (aux0 >> (l * 8)) & 255;

        /* Sign index: bits [l*7 .. l*7+6] of aux1 */
        uint sign_idx = (aux1 >> (l * 7)) & 127;

        /* Dequantize: grid_byte * signs */
        uint grid_val = grid_byte_at(grid_idx, j);
        uint signs = ksigns_iq2xs[sign_idx];
        float sign = (signs & kmask_iq2xs[j]) != 0 ? -1.0 : 1.0;

        acc += db * float(grid_val) * sign * x[b * 256 + c];
    }
    sums[lid] = acc;
    barrier();

    for (uint stride = gl_WorkGroupSize.x >> 1; stride > 0; stride >>= 1) {
        if (lid < stride) sums[lid] += sums[lid + stride];
        barrier();
    }
    if (lid == 0) y[row] = sums[0];
}
